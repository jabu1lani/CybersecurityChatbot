<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with bot name and ASCII art -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Margin="5" Padding="10">
            <StackPanel>
                <TextBlock Text="🛡️ CYBERSECURITY AWARENESS BOT 🛡️" 
                           FontSize="22" FontWeight="Bold" 
                           Foreground="#00FFAA" TextAlignment="Center"/>
                <TextBlock x:Name="AsciiArtBlock" 
                           Text="" 
                           FontFamily="Consolas" FontSize="10" 
                           Foreground="#00B4D8" TextAlignment="Center"
                           Visibility="Visible"/>
            </StackPanel>
        </Border>

        <!-- Chat display area -->
        <Border Grid.Row="2" Background="#0F0F1A" CornerRadius="10" Margin="5" Padding="10">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ChatDisplay" 
                           TextWrapping="Wrap" 
                           Foreground="White" 
                           FontSize="14"
                           FontFamily="Segoe UI"/>
            </ScrollViewer>
        </Border>

        <!-- Input area -->
        <Border Grid.Row="3" Background="#16213E" CornerRadius="10" Margin="5" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput" 
                         Grid.Column="0"
                         FontSize="14" 
                         Padding="10" 
                         Background="#1A1A2E"
                         Foreground="White"
                         BorderBrush="#00FFAA"
                         BorderThickness="1"
                         KeyDown="UserInput_KeyDown"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="📤 SEND" 
                        FontSize="14" 
                        Width="100" 
                        Margin="10,0,0,0"
                        Background="#00FFAA" 
                        Foreground="#1A1A2E"
                        FontWeight="Bold"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>